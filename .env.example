# ══════════════════════════════════════════════════════════════════
# Instagram AI Agent — Environment Variables Template
# Copy this file to .env and fill in your credentials
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Google Gemini AI ──────────────────────────────────────────────
# Get free API key: https://aistudio.google.com/app/apikeys
# Free tier: 60 requests/min · 1,500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# ── Instagram Graph API ───────────────────────────────────────────
# Requires Instagram Business or Creator account
# Setup: https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here

# ── Facebook App Credentials (optional — enables token refresh) ───
# Get from: https://developers.facebook.com/apps
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ── Cloudinary (required — Instagram needs public HTTPS image URLs) ─
# Free account: https://cloudinary.com (25 GB storage · 25 GB bandwidth/month)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ── Scheduler — Post times in 24-hour format (HH:MM) ─────────────
POST_TIME_MORNING=09:00
POST_TIME_EVENING=18:00
